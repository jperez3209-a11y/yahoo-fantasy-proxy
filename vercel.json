{
  "version": 2,
  "functions": {
    "api/token.js": { "memory": 128, "maxDuration": 10 },
    "api/yahoo.js": { "memory": 128, "maxDuration": 15 },
    "api/savant.js": { "memory": 256, "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
